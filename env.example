# =============================================================================
# NEET Book Bot — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- LLM (Groq) ---
# Get a free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=openai/gpt-oss-120b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# --- Retrieval (book search) ---
# How many chunks of the book to pull into context per question
RETRIEVAL_TOP_K=6
# Minimum similarity score (0-1) for a chunk to be considered relevant.
# If nothing meets this bar, the bot will say the book doesn't cover it.
RETRIEVAL_MIN_SCORE=0.05
# Word count per chunk when the book is ingested, and overlap between chunks
CHUNK_SIZE_WORDS=220
CHUNK_OVERLAP_WORDS=40

# --- Redis (Conversation Memory) ---
# If not configured, falls back to in-memory storage (lost on restart)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SESSION_TTL=3600

# --- Flask ---
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-string
# Keep this "false" in production/Vercel. Only set to "true" for local dev.
FLASK_DEBUG=false
LOG_LEVEL=INFO

# --- Deployment (auto-set by Vercel) ---
# PORT=10000
# SITE_URL=https://your-neet-bot.vercel.app
